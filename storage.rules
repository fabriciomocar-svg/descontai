rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Funções auxiliares
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Regra geral: Leitura pública para tudo (necessário para exibir imagens no app)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Logos de Lojas:
    // - Caminho: logos/{userId}/{fileName}
    // - Apenas o dono (lojista) pode fazer upload/deletar
    match /logos/{userId}/{fileName} {
      allow write: if isOwner(userId)
                   && request.resource.size < 5 * 1024 * 1024 // Max 5MB
                   && request.resource.contentType.matches('image/.*');
      allow delete: if isOwner(userId);
    }

    // Capas de Lojas:
    // - Caminho: covers/{userId}/{fileName}
    // - Apenas o dono (lojista) pode fazer upload/deletar
    match /covers/{userId}/{fileName} {
      allow write: if isOwner(userId)
                   && request.resource.size < 10 * 1024 * 1024 // Max 10MB
                   && request.resource.contentType.matches('image/.*');
      allow delete: if isOwner(userId);
    }
    
    // Mídia de Promoções (Imagens/Vídeos):
    // - Caminho: promotions/{userId}/{fileName}
    // - Apenas o dono (lojista) pode fazer upload/deletar
    match /promotions/{userId}/{fileName} {
      allow write: if isOwner(userId)
                   && request.resource.size < 50 * 1024 * 1024 // Max 50MB
                   && (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('video/.*'));
      allow delete: if isOwner(userId);
    }

    // Fotos de Perfil de Usuários:
    // - Caminho: profiles/{userId}/{fileName}
    match /profiles/{userId}/{fileName} {
      allow write: if isOwner(userId)
                   && request.resource.size < 5 * 1024 * 1024 // Max 5MB
                   && request.resource.contentType.matches('image/.*');
      allow delete: if isOwner(userId);
    }
  }
}
