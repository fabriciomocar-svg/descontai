rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funções auxiliares
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isMerchant() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'MERCHANT';
    }

    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // Regras para Usuários
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Regras para Lojas
    match /stores/{storeId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || (isMerchant() && resource.data.ownerEmail == request.auth.token.email);
      allow delete: if isAdmin();
    }

    // Regras para Promoções
    match /promotions/{promoId} {
      allow read: if true;
      allow create: if isMerchant() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.merchantId;
      allow update, delete: if isMerchant() && resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.merchantId;
    }

    // Regras para Chats
    match /chats/{chatId} {
      allow read, write: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.merchantId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.merchantId);
      allow create: if isAuthenticated();
    }
    
    // Regras para Mensagens dentro de Chats
    match /chats/{chatId}/messages/{messageId} {
       allow read, write: if isAuthenticated(); // Simplificado, idealmente checar parent
    }
  }
}
